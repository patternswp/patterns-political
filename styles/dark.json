{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Dark",
    "settings": {
        "color": {
            "palette": [
                {
                    "color": "#212529",
                    "name": "Base",
                    "slug": "base"
                },
                {
                    "color": "#fff",
                    "name": "Default",
                    "slug": "default"
                },
                {
                    "color": "#6C757D",
                    "name": "Primary",
                    "slug": "primary",
                    "_comment": "Lightened from #343A40 (1.5:1 contrast on base) to #6C757D for WCAG AA 4.5:1."
                },
                {
                    "color": "#2E3133",
                    "name": "Secondary",
                    "slug": "secondary"
                },
                {
                    "color": "#f4f4f4",
                    "name": "Tertiary",
                    "slug": "tertiary"
                },
                {
                    "color": "#686868",
                    "name": "Quaternary",
                    "slug": "quaternary"
                },
                {
                    "color": "#DBDBDB",
                    "name": "Quinary",
                    "slug": "quinary"
                },
                {
                    "color": "#000000",
                    "name": "Accent",
                    "slug": "accent"
                }
            ],
            "duotone": [
                {
                    "colors": [
                        "#212529",
                        "#6c757d"
                    ],
                    "slug": "base-to-primary",
                    "name": "Base to Primary"
                },
                {
                    "colors": [
                        "#212529",
                        "#2e3133"
                    ],
                    "slug": "base-to-secondary",
                    "name": "Base to Secondary"
                },
                {
                    "colors": [
                        "#fff",
                        "#6c757d"
                    ],
                    "slug": "white-to-primary",
                    "name": "White to Primary"
                },
                {
                    "colors": [
                        "#fff",
                        "#000000"
                    ],
                    "slug": "white-to-accent",
                    "name": "White to Accent"
                },
                {
                    "colors": [
                        "#f4f4f4",
                        "#2e3133"
                    ],
                    "slug": "tertiary-to-secondary",
                    "name": "Tertiary to Secondary"
                },
                {
                    "colors": [
                        "#212529",
                        "#dbdbdb"
                    ],
                    "slug": "base-to-quinary",
                    "name": "Base to Quinary"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var:preset|color|base",
            "text": "var:preset|color|default"
        },
        "elements": {
            "button": {
                "color": {
                    "background": "var:preset|color|secondary",
                    "text": "var:preset|color|default"
                },
                ":hover": {
                    "color": {
                        "background": "var:preset|color|accent"
                    }
                },
                ":focus": {
                    "color": {
                        "background": "var:preset|color|accent"
                    }
                },
                ":active": {
                    "color": {
                        "background": "var:preset|color|accent"
                    }
                },
                ":visited": {
                    "color": {
                        "text": "var:preset|color|default"
                    }
                }
            },
            "link": {
                ":active": {
                    "color": {
                        "text": "var:preset|color|primary"
                    }
                }
            }
        },
        "blocks": {
            "core/button": {
                "variations": {
                    "outline": {
                        "border": {
                            "color": "var(--wp--preset--color--secondary)"
                        },
                        "color": {
                            "text": "var:preset|color|secondary"
                        },
                        "css": ".wp-block-button__link:not(.has-background):hover {background:var(--wp--preset--color--primary);color: var(--wp--preset--color--default);} border-color: var(--wp--preset--color--primary);",
                        "elements": {
                            "link": {
                                ":hover": {
                                    "border": {
                                        "color": "var:preset|color|base"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
